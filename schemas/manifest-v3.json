{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes.local/sublation/manifest-v3.json",
  "title": "Skill Sublation Candidate Manifest v3",
  "type": "object",
  "required": ["schema_version", "candidate_id", "candidate_type", "source_skill", "candidate", "scope", "validation"],
  "properties": {
    "schema_version": { "const": 3 },
    "candidate_id": { "type": "string", "minLength": 1 },
    "candidate_type": { "enum": ["spec-patch", "script-enhance", "infra-fix", "tooling"] },
    "created_by": { "type": "string" },
    "created_at": { "type": "string" },
    "source_skill": { "$ref": "#/$defs/file_tree" },
    "candidate": { "$ref": "#/$defs/file_tree" },
    "scope": {
      "type": "object",
      "required": ["changes", "out_of_scope"],
      "properties": {
        "changes": { "type": "array", "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } }
      }
    },
    "breaking_changes": { "type": "array", "items": { "type": "string" } },
    "backward_compat": { "type": ["boolean", "null"] },
    "relationships": {
      "type": "object",
      "required": ["sublation_pattern", "target_skill"],
      "properties": {
        "sublation_pattern": {
          "enum": ["single_skill_patch", "cross_skill_absorption", "skill_merge_plan", "skill_split_plan"]
        },
        "target_skill": { "$ref": "#/$defs/skill_ref" },
        "donor_skills": {
          "type": "array",
          "items": { "$ref": "#/$defs/donor_skill_ref" }
        },
        "note": { "type": "string" }
      }
    },
    "rights_provenance": {
      "type": "object",
      "properties": {
        "policy": { "type": "string" },
        "donor_rights": {
          "type": "array",
          "items": { "$ref": "#/$defs/donor_rights_ref" }
        }
      }
    },
    "external_evaluations": {
      "type": "array",
      "items": { "$ref": "#/$defs/external_evaluation" }
    },
    "redacted_reporting": { "$ref": "#/$defs/redacted_reporting" },
    "rollback_hashes": { "type": "object", "additionalProperties": { "type": "string" } },
    "trigger_observations": { "type": "array", "items": { "type": "string" } },
    "validation": {
      "type": "object",
      "required": ["auditor_status", "cross_reviewed_by", "promotion_mode", "status"],
      "properties": {
        "auditor_status": { "enum": ["passed", "conditional", "failed"] },
        "cross_reviewed_by": { "enum": ["none", "hermes", "codex", "both", "claude-code", "all", "configured", "user-waived"] },
        "promotion_mode": { "enum": ["none", "human_patch", "user_delegated_agent_patch", "rollback"] },
        "status": { "enum": ["draft", "validated", "review_pending", "approved", "promoted", "observation_window", "closed", "rejected"] },
        "formal_post_promotion": { "$ref": "#/$defs/file_tree" },
        "post_promotion_safety": { "$ref": "#/$defs/post_promotion_safety" },
        "value_delta": { "$ref": "#/$defs/value_delta" },
        "empirical_scorecard": { "$ref": "#/$defs/empirical_scorecard" },
        "pre_promotion_reports": {
          "type": "array",
          "items": { "$ref": "#/$defs/pre_promotion_report" }
        },
        "review_policy": { "$ref": "#/$defs/review_policy" },
        "decision_history": {
          "type": "array",
          "items": { "$ref": "#/$defs/decision_history_event" }
        },
        "independent_reproduction": { "$ref": "#/$defs/independent_reproduction" },
        "rejected_alternatives": {
          "type": "array",
          "items": { "$ref": "#/$defs/rejected_alternative" }
        },
        "fixture_assertions_passed": { "type": "integer", "minimum": 0 },
        "promoted_by": { "type": "string" },
        "promoted_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "closed_at": { "type": "string" },
        "closure_reason": { "type": "string" },
        "closure_evidence": { "type": "array", "items": { "type": "string" } },
        "closure_reviewed_by": { "enum": ["none", "hermes", "codex", "both", "claude-code", "all", "configured", "user-waived"] },
        "closure_policy": { "type": "string" },
        "rejection_reason": {
          "enum": ["obsolete_superseded", "rejected_by_user", "failed_validation", "out_of_scope", "duplicate", "other"]
        },
        "superseded_by": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  },
  "$defs": {
    "file_tree": {
      "type": "object",
      "required": ["path", "tree_hash", "files"],
      "properties": {
        "path": { "type": "string" },
        "tree_hash": { "type": "string", "pattern": "^sha256:" },
        "files": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "skill_ref": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string" }
      }
    },
    "donor_skill_ref": {
      "type": "object",
      "required": ["name", "path", "absorbed_capability"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "absorbed_capability": { "type": "string", "minLength": 1 },
        "retained_boundary": { "type": "string" }
      }
    },
    "donor_rights_ref": {
      "type": "object",
      "required": ["skill_name", "path", "license", "provenance", "absorbed_material", "expression_copied", "permission_basis"],
      "properties": {
        "skill_name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "minLength": 1 },
        "absorbed_material": { "type": "string", "minLength": 1 },
        "expression_copied": { "type": "boolean" },
        "permission_basis": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "external_evaluation": {
      "type": "object",
      "required": ["evaluator", "target", "mode", "report_path", "formal_skill_modified"],
      "properties": {
        "evaluator": { "type": "string", "minLength": 1 },
        "target": { "enum": ["candidate"] },
        "mode": { "enum": ["read_only_scorecard", "proposal_only", "dry_run"] },
        "report_path": { "type": "string", "minLength": 1 },
        "formal_skill_modified": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "review_policy": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["default_three_agent", "configured_multi_agent", "single_agent", "user_waived"] },
        "coordinator": { "type": "string", "minLength": 1 },
        "policy_authorized_by": { "enum": ["user"] },
        "authorization_message_id": { "type": "string", "minLength": 1 },
        "authorization_report_path": { "type": "string", "minLength": 1 },
        "required_roles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "min_required_reviews": { "type": "integer", "minimum": 1 },
        "allow_same_agent_multiple_roles": { "type": "boolean" },
        "role_assignments": {
          "type": "array",
          "items": { "$ref": "#/$defs/review_role_assignment" }
        },
        "notes": { "type": "string" }
      }
    },
    "review_role_assignment": {
      "type": "object",
      "required": ["role", "agent"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "agent": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "independence": { "enum": ["independent", "same_agent", "user", "external", "not_available"] },
        "notes": { "type": "string" }
      }
    },
    "pre_promotion_report": {
      "type": "object",
      "required": ["reviewer", "status", "focus"],
      "properties": {
        "reviewer": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "independence": { "enum": ["independent", "same_agent", "user", "external", "not_available"] },
        "status": { "enum": ["approve", "hold", "reject", "info"] },
        "focus": { "type": "string", "minLength": 1 },
        "message_id": { "type": "string" },
        "report_path": { "type": "string" },
        "reported_at": { "type": "string" },
        "key_points": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "risks": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "recommendation": { "enum": ["proceed", "revise", "reject", "defer"] },
        "notes": { "type": "string" }
      }
    },
    "decision_history_event": {
      "type": "object",
      "required": ["event_id", "phase", "trigger", "diagnosis", "action", "evidence", "outcome"],
      "properties": {
        "event_id": { "type": "string", "minLength": 1 },
        "phase": {
          "enum": ["candidate_revision", "pre_promotion_review", "promotion", "observation_window", "closure"]
        },
        "trigger": {
          "type": "object",
          "required": ["kind", "id", "by"],
          "properties": {
            "kind": {
              "enum": ["report", "audit", "smoke_test", "user_decision", "observation", "external_paper", "manual_review"]
            },
            "id": { "type": "string", "minLength": 1 },
            "by": { "type": "string", "minLength": 1 },
            "notes": { "type": "string" }
          }
        },
        "diagnosis": { "type": "string", "minLength": 1 },
        "action": {
          "type": "object",
          "required": ["kind", "summary"],
          "properties": {
            "kind": { "enum": ["revision", "audit", "smoke_test", "report", "observation", "no_change"] },
            "summary": { "type": "string", "minLength": 1 },
            "changed_paths": { "type": "array", "items": { "type": "string", "minLength": 1 } }
          }
        },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "outcome": {
          "type": "object",
          "required": ["status", "summary"],
          "properties": {
            "status": { "enum": ["resolved", "held", "rejected", "approved", "deferred", "observed"] },
            "summary": { "type": "string", "minLength": 1 },
            "follow_up": { "type": "string" }
          }
        }
      }
    },
    "independent_reproduction": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["passed", "pending", "failed", "not_required"] },
        "performed_by": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "scope": { "type": "string" },
        "method": { "enum": ["audit", "fixture", "smoke_test", "manual_review", "mixed"] },
        "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "not_required_reason": { "type": "string" }
      }
    },
    "rejected_alternative": {
      "type": "object",
      "required": ["alternative", "scope", "reason_rejected", "retained_learning"],
      "properties": {
        "alternative": { "type": "string", "minLength": 1 },
        "scope": { "enum": ["design_fork", "spec_patch", "absorption", "review_conflict", "routing"] },
        "reason_rejected": { "type": "string", "minLength": 1 },
        "retained_learning": { "type": "string", "minLength": 1 },
        "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "redacted_reporting": {
      "type": "object",
      "required": ["shareable_evidence", "local_only_evidence", "sensitive_context_classes"],
      "properties": {
        "shareable_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "local_only_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "sensitive_context_classes": {
          "type": "array",
          "items": {
            "enum": [
              "credential_path",
              "cookie_path",
              "login_session",
              "page_body",
              "user_data",
              "contract_data",
              "private_chat",
              "other"
            ]
          }
        },
        "redaction_policy": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "post_promotion_safety": {
      "type": "object",
      "properties": {
        "rollback_ready": { "type": "boolean" },
        "rollback_point": { "type": "string" },
        "target_path_verified": { "type": "boolean" },
        "source_path_matches_promotion_target": { "type": ["boolean", "null"] },
        "target_path_note": { "type": "string" },
        "business_smoke_test": {
          "type": "object",
          "properties": {
            "status": { "enum": ["passed", "pending", "failed", "not_required"] },
            "evidence": { "type": "array", "items": { "type": "string" } }
          }
        },
        "fallback_verified": { "type": ["boolean", "null"] },
        "old_capability_retained": { "type": ["boolean", "null"] },
        "skillspector": { "$ref": "#/$defs/skillspector_post_promotion" },
        "notes": { "type": "string" }
      }
    },
    "skillspector_post_promotion": {
      "type": "object",
      "required": ["status", "tool", "mode", "recommendation_gating"],
      "properties": {
        "status": {
          "enum": [
            "not_run",
            "baseline_recorded",
            "triaged",
            "blocked",
            "passed",
            "not_required"
          ]
        },
        "tool": { "const": "skillspector" },
        "version": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["static_no_llm", "static_with_llm"] },
        "command": { "type": "string", "minLength": 1 },
        "target_path": { "type": "string", "minLength": 1 },
        "baseline_report_path": { "type": "string", "minLength": 1 },
        "baseline_fingerprint": { "type": "string", "pattern": "^sha256:" },
        "baseline_tool_version": { "type": "string", "minLength": 1 },
        "closing_report_path": { "type": "string", "minLength": 1 },
        "current_fingerprint": { "type": "string", "pattern": "^sha256:" },
        "risk_score": { "type": "number" },
        "severity": { "type": "string" },
        "recommendation": { "type": "string" },
        "recommendation_gating": { "const": false },
        "severity_histogram": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "yara_namespaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "full_findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/skillspector_finding" }
        },
        "new_findings_since_baseline": {
          "type": "array",
          "items": { "$ref": "#/$defs/skillspector_finding" }
        },
        "new_malware_yara_findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/skillspector_finding" }
        },
        "new_confirmed_high_or_critical_untriaged_findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/skillspector_finding" }
        },
        "triage": {
          "type": "array",
          "items": { "$ref": "#/$defs/skillspector_triage_item" }
        },
        "version_change_policy": {
          "enum": ["same_version_required", "rebaseline_and_human_review_required"]
        },
        "closure_decision": {
          "enum": ["not_evaluated", "allow_closure", "block_closure", "keep_observing", "rebaseline_required"]
        },
        "notes": { "type": "string" }
      }
    },
    "skillspector_finding": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "severity": { "type": "string" },
        "category": { "type": "string" },
        "pattern": { "type": "string" },
        "yara_namespace": { "type": "string" },
        "location": { "type": "string" },
        "fingerprint": { "type": "string" },
        "confirmed": { "type": "boolean" },
        "triage_status": {
          "enum": ["untriaged", "accepted_risk", "false_positive", "remediation_required", "remediated"]
        },
        "notes": { "type": "string" }
      }
    },
    "skillspector_triage_item": {
      "type": "object",
      "required": ["finding", "decision", "reason"],
      "properties": {
        "finding": { "type": "string", "minLength": 1 },
        "decision": {
          "enum": ["accepted_risk", "false_positive", "remediation_required", "remediated", "defer"]
        },
        "reason": { "type": "string", "minLength": 1 },
        "control": { "type": "string" },
        "reviewed_by": { "type": "string" },
        "reviewed_at": { "type": "string" }
      }
    },
    "value_delta": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["positive_delta", "not_applicable", "unproven", "regressed"] },
        "positive_delta_categories": {
          "type": "array",
          "items": {
            "enum": [
              "capability_strength",
              "capability_scope",
              "boundary_clarity",
              "reliability",
              "maintainability",
              "safety",
              "governance_quality"
            ]
          }
        },
        "summary": { "type": "string", "minLength": 1 },
        "evidence": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "regression_risks": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "old_capability_retained": { "type": "boolean" },
        "capability_reduction": { "type": "boolean" },
        "fallback_or_rollback": { "type": "string", "minLength": 1 },
        "observation_acceptance": { "type": "string", "minLength": 1 },
        "user_approval_note": { "type": "string" },
        "not_applicable_reason": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    },
    "empirical_scorecard": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["measured", "not_applicable", "not_measured"] },
        "metric_name": { "type": "string", "minLength": 1 },
        "baseline_score": { "type": "number" },
        "candidate_score": { "type": "number" },
        "higher_is_better": { "type": "boolean" },
        "fixture_or_dataset": { "type": "string", "minLength": 1 },
        "evaluator": { "type": "string", "minLength": 1 },
        "regression_checks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "decision": {
          "enum": [
            "improved",
            "neutral",
            "regressed",
            "blocked",
            "accepted_by_review",
            "not_applicable",
            "deferred"
          ]
        },
        "not_applicable_reason": { "type": "string", "minLength": 1 },
        "not_measured_reason": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    }
  }
}
