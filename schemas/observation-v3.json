{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes.local/sublation/observation-v3.json",
  "title": "Skill Sublation Observation v3",
  "type": "object",
  "required": [
    "schema_version",
    "timestamp",
    "skill_name",
    "skill_content_hash",
    "source_session_hash",
    "classification",
    "reflection_type",
    "confidence",
    "trace_completeness",
    "step_details",
    "summary",
    "recommendation"
  ],
  "properties": {
    "schema_version": { "const": 3 },
    "timestamp": { "type": "string" },
    "skill_name": { "type": "string", "minLength": 1 },
    "skill_path": { "type": ["string", "null"] },
    "skill_content_hash": { "type": "string", "pattern": "^sha256:" },
    "source_session_hash": { "type": "string", "pattern": "^sha256:" },
    "source_session": { "type": "string" },
    "classification": { "enum": ["clean", "partial", "defect", "critical"] },
    "reflection_type": { "enum": ["DISCOVERY", "OPTIMIZATION", "SKILL_DEFECT", "EXECUTION_LAPSE"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "trace_completeness": { "type": "number", "minimum": 0, "maximum": 1 },
    "step_details": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step", "status", "evidence_short", "confidence"],
        "properties": {
          "step": { "type": "string" },
          "status": { "type": "string" },
          "sub_label": { "type": "string" },
          "evidence_short": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "summary": { "type": "string" },
    "recommendation": { "enum": ["obs_only", "flag_for_review", "create_candidate"] }
  }
}

